---
import { site } from "@/config/site";
import { t }    from "@/i18n/utils";
import { stats } from "@/i18n/stats";
import type { Locale } from "@/i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;

const yearsActive = Math.max(new Date().getFullYear() - site.foundedYear, 1);

const items = [
  { value: `${yearsActive}+`, label: t(stats.yearsExperience,    locale) },
  { value: "20+",             label: t(stats.projectsDelivered,  locale) },
  { value: "100%",            label: t(stats.clientSatisfaction, locale) },
  { value: "<24h",            label: t(stats.responseTime,       locale) },
];
---

<section class="border-y border-border bg-muted/30 py-12">
  <div class="container mx-auto px-4">
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {items.map(({ value, label }) => (
        <div>
          <dt class="text-3xl md:text-4xl font-bold text-primary">{value}</dt>
          <dd class="text-sm text-foreground/60 mt-1">{label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
