---
import { t } from "@/i18n/utils";
import { faqSection, faqItems } from "@/i18n/faq";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
  maxItems?: number;
}

const { locale, maxItems } = Astro.props;
const displayed = maxItems ? faqItems.slice(0, maxItems) : faqItems;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: displayed.map((item) => ({
    "@type": "Question",
    name: t(item.question, locale),
    acceptedAnswer: {
      "@type": "Answer",
      text: t(item.answer, locale),
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<section class="py-20 md:py-28">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        {t(faqSection.heading, locale)}
      </h2>
      <p class="text-lg text-foreground/60">
        {t(faqSection.subheading, locale)}
      </p>
    </div>

    <div class="max-w-2xl mx-auto divide-y divide-border">
      {displayed.map((item) => (
        <details class="group py-4">
          <summary class="flex items-center justify-between cursor-pointer list-none gap-4">
            <span class="font-medium text-base">
              {t(item.question, locale)}
            </span>
            <span
              class="shrink-0 text-primary text-xl leading-none transition-transform group-open:rotate-45"
              aria-hidden="true"
            >+</span>
          </summary>
          <p class="mt-3 text-sm text-foreground/60 leading-relaxed">
            {t(item.answer, locale)}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>
