---
import { t } from "@/i18n/utils";
import { howItWorksSection, howItWorksSteps } from "@/i18n/how-it-works";
import type { Locale } from "@/i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
---

<section class="py-20 md:py-28 bg-muted/20">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        {t(howItWorksSection.heading, locale)}
      </h2>
      <p class="text-lg text-foreground/60">
        {t(howItWorksSection.subheading, locale)}
      </p>
    </div>

    <ol class="relative max-w-3xl mx-auto">
      <div class="absolute left-6 top-8 bottom-8 w-px bg-border md:left-8" aria-hidden="true"></div>

      {howItWorksSteps.map((step, i) => (
        <li class="relative flex gap-6 md:gap-8 pb-10 last:pb-0">
          <div class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full border-2 border-primary bg-background text-primary font-bold text-sm md:h-16 md:w-16 md:text-base">
            {String(i + 1).padStart(2, "0")}
          </div>

          <div class="pt-2 pb-2">
            <h3 class="font-semibold text-lg mb-2">
              {locale === "tr" ? step.titleTr : step.titleEn}
            </h3>
            <p class="text-sm text-foreground/60 leading-relaxed max-w-lg">
              {locale === "tr" ? step.descTr : step.descEn}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
