---
import BaseLayout      from "@/layouts/BaseLayout.astro";
import HeroSection     from "@/components/sections/HeroSection.astro";
import ServicesSection from "@/components/sections/ServicesSection.astro";
import CtaSection      from "@/components/sections/CtaSection.astro";
import { getLangFromUrl } from "@/i18n/utils";

const locale      = getLangFromUrl(Astro.url);
const title       = locale === "tr" ? "Hizmetler"                                                       : "Services";
const description = locale === "tr" ? "FixRav'ın sunduğu web tasarım ve geliştirme hizmetleri."
                                    : "Web design and development services offered by FixRav.";
---

<BaseLayout {title} {description}>
  <HeroSection     locale={locale} page="services" />
  <ServicesSection locale={locale}                 />
  <CtaSection      locale={locale}                 />
</BaseLayout>
