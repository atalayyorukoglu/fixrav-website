---
import BaseLayout         from "@/layouts/BaseLayout.astro";
import HeroSection        from "@/components/sections/HeroSection.astro";
import HowItWorksSection  from "@/components/sections/HowItWorksSection.astro";
import CtaSection         from "@/components/sections/CtaSection.astro";
import { getLangFromUrl } from "@/i18n/utils";

const locale      = getLangFromUrl(Astro.url);
const title       = locale === "tr" ? "Süreç Nasıl İşler"                            : "How It Works";
const description = locale === "tr" ? "FixRav'da briften lansmanına web sitesi geliştirme süreci."
                                    : "Our web development process from brief to launch at FixRav.";
---

<BaseLayout {title} {description}>
  <HeroSection       locale={locale} page="how-it-works" />
  <HowItWorksSection locale={locale}                     />
  <CtaSection        locale={locale}                     />
</BaseLayout>
