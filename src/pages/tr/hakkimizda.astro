---
import BaseLayout          from "@/layouts/BaseLayout.astro";
import HeroSection         from "@/components/sections/HeroSection.astro";
import StatsSection        from "@/components/sections/StatsSection.astro";
import TeamSection         from "@/components/sections/TeamSection.astro";
import TestimonialsSection from "@/components/sections/TestimonialsSection.astro";
import CtaSection          from "@/components/sections/CtaSection.astro";
import { getLangFromUrl }  from "@/i18n/utils";

const locale      = getLangFromUrl(Astro.url);
const title       = locale === "tr" ? "Hakkımızda"                                           : "About Us";
const description = locale === "tr" ? "FixRav hakkında: kim olduğumuz ve ne yaptığımız."
                                    : "Learn about FixRav — who we are and what we do.";
---

<BaseLayout {title} {description}>
  <HeroSection         locale={locale} page="about"       />
  <StatsSection        locale={locale}                    />
  <TeamSection         locale={locale}                    />
  <TestimonialsSection locale={locale} featured={true}    />
  <CtaSection          locale={locale}                    />
</BaseLayout>
