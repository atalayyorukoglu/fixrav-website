---
import BaseLayout      from "@/layouts/BaseLayout.astro";
import HeroSection     from "@/components/sections/HeroSection.astro";
import PricingSection  from "@/components/sections/PricingSection.astro";
import FaqSection      from "@/components/sections/FaqSection.astro";
import CtaSection      from "@/components/sections/CtaSection.astro";
import { getLangFromUrl } from "@/i18n/utils";

const locale      = getLangFromUrl(Astro.url);
const title       = locale === "tr" ? "Fiyatlar"                                       : "Pricing";
const description = locale === "tr" ? "FixRav web geliştirme hizmetleri için şeffaf fiyat paketleri."
                                    : "Transparent pricing packages for FixRav web development services.";
---

<BaseLayout {title} {description}>
  <HeroSection    locale={locale} page="pricing"  />
  <PricingSection locale={locale}                 />
  <FaqSection     locale={locale} maxItems={3}    />
  <CtaSection     locale={locale}                 />
</BaseLayout>
